# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# NEVER commit .env to GitHub — it contains secrets!
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (from MongoDB Atlas → Connect → Drivers)
# Leave blank to use JSON file fallback (predictions.json)
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/?appName=Cluster0

# Firebase Firestore cloud database
# If configured, Firebase is used before MongoDB and the local JSON fallback.
# Recommended locally: download a Firebase service account JSON and point to it.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=secrets/firebase-service-account.json

# Alternative for hosted deployments: paste the full service account JSON as one env var.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Upload performance tuning
# Schema detection samples only the first rows; upload-time analysis is capped
# so large CSV/JSON files return quickly. Use POST /files/scan for deeper scans.
UPLOAD_SCHEMA_SAMPLE_ROWS=250
AUTO_UPLOAD_ANALYSIS_ROWS=1000
UPLOAD_WRITE_CHUNK_BYTES=1048576

# Environment tag (development | production)
ENVIRONMENT=development

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Allowed frontend origins (comma-separated) for React/Vite apps.
# Include the Vite dev server (5173) and preview server (4173) for local
# development. Add your deployed frontend URL(s) for production.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,https://curious-torte-a466b6.netlify.app,https://timely-raindrop-e657e5.netlify.app

# API reliability controls
REQUEST_TIMEOUT_S=15
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_MAX_KEYS=10000
RATE_LIMIT_CLEANUP_INTERVAL=200

# Balanced binary decision thresholds
# approve if confidence >= POSITIVE_THRESHOLD
# reject if confidence <= NEGATIVE_THRESHOLD
# otherwise keep model decision (uncertainty band)
HIRING_POSITIVE_THRESHOLD=0.55
HIRING_NEGATIVE_THRESHOLD=0.45
LOAN_POSITIVE_THRESHOLD=0.55
LOAN_NEGATIVE_THRESHOLD=0.45
