# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# NEVER commit .env to GitHub — it contains secrets!
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (from MongoDB Atlas → Connect → Drivers)
# Leave blank to use JSON file fallback (predictions.json)
MONGO_URL=

# Environment tag (development | production)
ENVIRONMENT=development

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Allowed frontend origins (comma-separated) for React/Vite apps
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API reliability controls
REQUEST_TIMEOUT_S=15
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_MAX_KEYS=10000
RATE_LIMIT_CLEANUP_INTERVAL=200

# Balanced binary decision thresholds
# approve if confidence >= POSITIVE_THRESHOLD
# reject if confidence <= NEGATIVE_THRESHOLD
# otherwise keep model decision (uncertainty band)
HIRING_POSITIVE_THRESHOLD=0.55
HIRING_NEGATIVE_THRESHOLD=0.45
LOAN_POSITIVE_THRESHOLD=0.55
LOAN_NEGATIVE_THRESHOLD=0.45
